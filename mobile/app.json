{
  "expo": {
    "name": "MeydanFest",
    "slug": "meydanfest",
    "version": "1.3.52",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "meydanfest",
    "userInterfaceStyle": "dark",
    "backgroundColor": "#08070D",
    "ios": {
      "icon": "./assets/expo.icon",
      "supportsTablet": true
    },
    "android": {
      "package": "app.meydanfest",
      "versionCode": 54,
      "adaptiveIcon": {
        "backgroundColor": "#08070D",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.RECORD_AUDIO",
        "android.permission.MODIFY_AUDIO_SETTINGS",
        "android.permission.FOREGROUND_SERVICE",
        "android.permission.FOREGROUND_SERVICE_MEDIA_PLAYBACK"
      ]
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-web-browser",
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "MeydanFest, bulunduğun şehirdeki etkinlikleri öne çıkarmak için konumunu kullanır."
        }
      ],
      "expo-notifications",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#08070D",
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 120,
          "dark": {
            "backgroundColor": "#08070D"
          }
        }
      ],
      "expo-audio",
      [
        "expo-image-picker",
        {
          "photosPermission": "MeydanFest, story ve gönderi paylaşman için galerine erişir.",
          "cameraPermission": "MeydanFest, story/fotoğraf çekmen için kameraya erişir."
        }
      ],
      "@react-native-community/datetimepicker",
      [
        "expo-calendar",
        {
          "calendarPermission": "MeydanFest, beğendiğin etkinlikleri telefonunun takvimine eklemek için takvime erişir."
        }
      ],
      [
        "react-native-android-widget",
        {
          "widgets": [
            {
              "name": "MeydanEvent",
              "label": "Meydan • Etkinlik",
              "description": "Yakınındaki bir sonraki etkinlik",
              "minWidth": "180dp",
              "minHeight": "110dp",
              "targetCellWidth": 4,
              "targetCellHeight": 2,
              "updatePeriodMillis": 1800000,
              "resizeMode": "horizontal|vertical"
            }
          ]
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": false,
      "inlineModules": {
        "watchedDirectories": [
          "modules"
        ]
      }
    },
    "extra": {
      "apiBase": "https://etkinlikscout.vercel.app",
      "apiKey": "meydanfest-app",
      "googleWebClientId": "89266680677-kdi8lcjvsu8n619l1a9aoovhu640cbnp.apps.googleusercontent.com",
      "googleAndroidClientId": "YOUR_ANDROID_CLIENT_ID.apps.googleusercontent.com",
      "router": {},
      "eas": {
        "projectId": "c0684327-7195-4af6-b068-5abf235f7f34"
      }
    },
    "owner": "ckapps"
  }
}
